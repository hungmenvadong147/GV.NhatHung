# ===========================================
# CẤU HÌNH SERVER
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# CLOUDINARY CONFIGURATION
# ===========================================
# Lấy thông tin từ: https://cloudinary.com/console
# Dashboard > Settings > API Keys

# Cloud Name (bắt buộc)
CLOUDINARY_CLOUD_NAME=

# API Key (bắt buộc) - Từ hình ảnh của bạn
CLOUDINARY_API_KEY=266483242265736

# API Secret (bắt buộc) - Click "Show" trên Cloudinary Dashboard để xem
CLOUDINARY_API_SECRET=

# ===========================================
# HƯỚNG DẪN:
# ===========================================
# 1. Copy file này thành .env
# 2. Điền CLOUDINARY_CLOUD_NAME (vd: my-learning-site)
# 3. Điền CLOUDINARY_API_SECRET (lấy từ Cloudinary Dashboard)
# 4. Lưu file và restart server
#
# Xem hướng dẫn chi tiết: CLOUDINARY_SETUP.md
# ===========================================
